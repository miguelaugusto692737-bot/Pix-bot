{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fuser -k ${PORT:-8080}/tcp 2>/dev/null || true; export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "npx tsc"
    "start": "node ./build.mjs && node --enable-source-maps ./dist/index.mjs"
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "discord.js": "^14.26.2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
    "typescript": "^5.0.0"
  }
}
